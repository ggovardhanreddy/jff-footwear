# Web
NEXT_PUBLIC_SITE_URL=https://www.jffstores.com
NEXT_PUBLIC_BASE_PATH=

# Supabase (free tier — https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key is ONLY for Edge Functions / server — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay (free to create; only pay % on successful charges)
# Use test keys first: https://dashboard.razorpay.com
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Gemini Vision — Edge Function secret ONLY (never NEXT_PUBLIC_*)
# Set via: npx supabase secrets set GEMINI_API_KEY=...
# GEMINI_API_KEY=

# Mobile
EXPO_PUBLIC_WEB_ASSET_BASE_URL=https://www.jffstores.com
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_REMOTE_CONFIG_URL=
EAS_PROJECT_ID=your-eas-project-id
APP_VARIANT=development

# GitHub Actions (repository secrets)
# EXPO_TOKEN=
# EAS_PROJECT_ID=
# DEPLOY_WEBHOOK_URL=   # optional Slack/Discord webhook
# SITE_URL=https://www.jffstores.com  # optional override for OTA asset base
