{
  "name": "jff-footwear",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@jff/web",
    "dev:mobile": "turbo dev --filter=@jff/mobile",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "generate": "turbo generate --filter=@jff/web",
    "deploy:pages": "npm run deploy:pages --workspace=@jff/web",
    "deps:update": "bash scripts/update-deps.sh minor",
    "deps:update:latest": "bash scripts/update-deps.sh latest",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "eslint": "^9.39.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.6",
    "turbo": "^2.10.6",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix --config apps/web/eslint.config.mjs",
      "prettier --write"
    ],
    "apps/mobile/**/*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "packages/**/*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2"
  }
}
