{
  "name": "jff-footwear",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node node_modules/.bin/next dev",
    "build": "node node_modules/.bin/next build",
    "export": "node node_modules/.bin/next build",
    "start": "node node_modules/.bin/next start",
    "lint": "node node_modules/.bin/next lint",
    "generate": "node node_modules/.bin/tsx scripts/generate-products.ts",
    "deploy": "npm run generate && NEXT_PUBLIC_BASE_PATH=/jff-footwear NEXT_PUBLIC_SITE_URL=https://ggovardhanreddy.github.io/jff-footwear node node_modules/.bin/next build && rm -rf docs && cp -r out docs",
    "prebuild": "npm run generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.469.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "yet-another-react-lightbox": "^3.21.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
