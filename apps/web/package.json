    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.5.20",
    "serve": "^14.2.4",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.19.2",
    "typescript": "^7.0.2"
