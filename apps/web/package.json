{
  "name": "@jff/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "echo \"@jff/web: no tests yet\"",
    "generate": "tsx scripts/generate-products.ts",
    "generate:catalog": "tsx scripts/generate-catalog.ts",
    "verify:sitemap": "tsx scripts/verify-sitemap.ts",
    "lighthouse": "lhci autorun",
    "deploy:pages": "npm run generate && npm run generate:catalog && NEXT_PUBLIC_SITE_URL=https://www.jffstores.com npm run build && rm -rf ../../docs && cp -r out ../../docs",
