    "@jff/types": "*",
    "@jff/ui": "*",
    "@jff/utils": "*",
    "@supabase/supabase-js": "^2.110.7",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "lucide-react": "^1.25.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.82.0",
    "yet-another-react-lightbox": "^3.21.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
